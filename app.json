{
  "expo": {
    "name": "AIMP Remote Control",
    "slug": "aimp-remote",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icons/adaptive-icon-color.png",
    "scheme": "aimpremote",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#363636",
        "foregroundImage": "./assets/icons/adaptive-icon-color.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.reitansora.aimpremote"
    },
    "primaryColor": "#FFFFFF",
    "web": {
      "output": "static",
      "favicon": "./assets/icons/adaptive-icon-color.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash/splash-icon-dark.png",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/splash/splash-icon-light.png"
          },
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/MPLUS-Bold.ttf",
            "./assets/fonts/MPLUS-ExtraBold.ttf",
            "./assets/fonts/MPLUS-Regular.ttf",
            "./assets/fonts/MPLUS-Medium.ttf",
            "./assets/fonts/MPLUS-Thin.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cca8de19-da90-4dff-bdec-f261cd0abbda"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cca8de19-da90-4dff-bdec-f261cd0abbda"
    }
  }
}
